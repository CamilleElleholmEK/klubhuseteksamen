  <path d="M14.2656 1.82107C14.7125 1.46852 14.4632 0.75 13.894 0.75L1.35263 0.75C0.78341 0.75 0.534117 1.46852 0.98102 1.82107L7.25168 6.76779C7.4696 6.9397 7.77698 6.9397 7.9949 6.76779L14.2656 1.82107Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg></button>
    </div>
