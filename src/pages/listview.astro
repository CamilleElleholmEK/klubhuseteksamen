    <a id="to-top" href="#glitchbox">To the top <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M0.981019 5.82566C0.534117 6.17821 0.78341 6.89673 1.35263 6.89673L13.894 6.89673C14.4632 6.89673 14.7125 6.17821 14.2656 5.82566L7.9949 0.878938C7.77698 0.70703 7.4696 0.70703 7.25168 0.878938L0.981019 5.82566Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
