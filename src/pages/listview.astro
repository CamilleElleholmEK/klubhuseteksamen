        <button class="filter-btn producer-btn" data-producer="peter">Peter Sloth</button>
        <button class="filter-btn producer-btn" data-producer="felix">Felix Ziska</button>
        <button class="filter-btn producer-btn" data-producer="joakim">Joakim Lambek</button>
      </div>
      <div class="filter-content" data-panel="genre" hidden>
        <button data-genre="Alternative" class="filter-btn genre-btn">Alternative</button>
        <button data-genre="Alternative Pop" class="filter-btn genre-btn">Alternative pop</button>
        <button data-genre="Alternative rock" class="filter-btn genre-btn">Alternative rock</button>
        <button data-genre="Ambient" class="filter-btn genre-btn">Ambient</button>
        <button data-genre="Chamber pop" class="filter-btn genre-btn">Chamber pop</button>
        <button data-genre="Classic" class="filter-btn genre-btn">Classic</button>
        <button data-genre="Contemporary" class="filter-btn genre-btn">Contemporary</button>
        <button data-genre="Contemporary jazz" class="filter-btn genre-btn">Contemporary jazz</button>
        <button data-genre="Dream pop" class="filter-btn genre-btn">Dream pop</button>
        <button data-genre="Electronic" class="filter-btn genre-btn">Electronic</button>
