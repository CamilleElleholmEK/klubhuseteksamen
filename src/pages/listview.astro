---
import "../css/custom.css"
import "../css/general.css"
import ListCard from "../components/ListCard.astro"
import ArtistLayout from "../layouts/ArtistLayout.astro"

const endpoint =
  "https://cslftqskycbszssbrjfq.supabase.co/rest/v1/artister?select=*"

const options = {
  headers: { apikey: "sb_publishable_uJBiElMI8evEQetR2TtT2g_2o4KGmfP" }};

const data = await fetch(endpoint, options).then((response) => response.json());


---

<ArtistLayout>
  <section class="topsection">
    <div id="glitchbox">
         <h1>Artists</h1>
         <!-- <p>Artists</p>
         <p>Artists</p> -->
         
        </div>
    <div class="filterbar">
      <div>
      <button class="filter-toggle" data-target="producer">Producer <svg class="svg" xmlns="http://www.w3.org/2000/svg" width="16" height="8" viewBox="0 0 16 8" fill="none">
  <path d="M14.2656 1.82107C14.7125 1.46852 14.4632 0.75 13.894 0.75L1.35263 0.75C0.78341 0.75 0.534117 1.46852 0.98102 1.82107L7.25168 6.76779C7.4696 6.9397 7.77698 6.9397 7.9949 6.76779L14.2656 1.82107Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg></button>
      <button class="filter-toggle" data-target="genre">Genre <svg class="svg" xmlns="http://www.w3.org/2000/svg" width="16" height="8" viewBox="0 0 16 8" fill="none">
  <path d="M14.2656 1.82107C14.7125 1.46852 14.4632 0.75 13.894 0.75L1.35263 0.75C0.78341 0.75 0.534117 1.46852 0.98102 1.82107L7.25168 6.76779C7.4696 6.9397 7.77698 6.9397 7.9949 6.76779L14.2656 1.82107Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg></button>
      </div> 
