</ArtistLayout>

<style>
  html {
    height: 100%;
  }
  
  body {
    margin-top: 128px;
    background-image: var(--gradient-dark);
    background-attachment: fixed;
    min-height: 100%;
  }

   section {
    margin: 0px 5vw 0px 5vw;
   }

   .topsection {
    margin-top: 40px;
    margin-bottom: 20px;
   }

   #glitchbox {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: 1fr;
    }

    /* #glitchbox h1, #glitchbox p{
        font-family: var(--gopher);
        font-size: var(--h1-size);
        font-weight: var(--bold);
        line-height: 85px;
        mix-blend-mode: screen;
        grid-row: 1/2;
        grid-column: 1/2;
    }

    #glitchbox h1:nth-child(1) {
        color: #f00;
        filter: blur(1.5px);
        mix-blend-mode: lighten;
    }

    #glitchbox p:nth-child(2) {
        color: #00fd00;
        mix-blend-mode: screen;
        filter: blur(4px);
        padding-left: 3px;
    }

    #glitchbox p:nth-child(3) {
        color: #0000ff;
        filter: blur(1.5px);
        mix-blend-mode: lighten;
        padding-left: 6px;
    } */


   button, #to-top {
    background-color: transparent;
    font-family: var(--stolzl);
    color: var(--secondary);
    border: none;
    text-decoration: none;
   }

   button:hover, #to-top:hover {
    color: var(--contrast);
   }

   button:hover svg, #to-top:hover svg {
    stroke: var(--contrast);
   }

   #sort:hover, #to-top:hover {
    border-color: var(--contrast);
   }

   #sort, .filter-btn, .sort-btn, #to-top {
    border: solid 1px var(--secondary);
   }

   .filter-btn, .sort-btn {
    padding: 3px 18px 3px 6px;
    border-top-right-radius: 75px;
   }

   #sort, #to-top {
    padding: 3px 6px 3px 18px;
    border-top-left-radius: 75px;
   }

   #sort svg {
    margin-left: 12vw;
   }

   .active {
    background-color: var(--contrast);
    border: solid 1px var(--contrast);
    stroke: var(--contrast);
   }

   svg {
    stroke: var(--secondary);
   }

   .activebtn svg {
    stroke: var(--contrast);
   }

   .activebtn {
    color: var(--contrast);
   }

   #sort.activebtn {
    border-color: var(--contrast) !important;
   }

   .filterbar {
    border-bottom: solid 0.5px var(--secondary);
    display: flex;
    justify-content: space-between;
    padding: 8px 0px;
    margin: 20px 0px 8px 0px;
   }

   .filterbar div button {
    padding: 3px 6px 3px 0px;
   }

   .filterbar div button:nth-child(2) {
    border-right: solid 1px var(--secondary);
    border-left: solid 1px var(--secondary);
    padding-left: 6px;
   }

   /* .filter-content {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr 1fr;
   } */

   .filter-btn {
    margin: 2px;
   }

   .projectcontainer {
    margin-bottom: 40px;
   }

   @media (min-width: 850px) {
    .projectcontainer {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      border-top: solid 0.5px var(--secondary);
      padding-top: 15px;
      padding-bottom: 15px;
      background: linear-gradient(to right, transparent 0%, transparent 49.9%, var(--secondary) 50%, transparent 50.1%);
    }

    .project {
      padding: 16px;
    }

    #glitchbox h1, #glitchbox p{
       font-size: var(--h1-size-desk);
       line-height: 200px;
       font-weight: var(--medium);
    }
   }
</style>

<script>
  // @ts-nocheck

  // Viser og skjuler filtreringspaneler
  const toggles = document.querySelectorAll<HTMLElement>(".filter-toggle");
  const panels = document.querySelectorAll<HTMLElement>(".filter-content");
  const svg = document.querySelectorAll<HTMLElement>(".svg")
  

  toggles.forEach(toggle => {
  toggle.addEventListener("click", () => {
    const target = toggle.dataset.target;
    const targetPanel = [...panels].find(p => p.dataset.panel === target);

    panels.forEach(p => {
      if (p.dataset.panel !== target) p.hidden = true;
    });
    // Fjern active fra andre toggles
    toggles.forEach(t => { if (t !== toggle) t.classList.remove("activebtn") });

    targetPanel.hidden = !targetPanel.hidden;
    toggle.classList.toggle("activebtn", !targetPanel.hidden);
   });
   });


// Funktion der lytter på knapper, ændrer deres udseende og sender videre til rette filtrering
  document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', btnActive );
});

function btnActive(e) {
  const valgt = e.target;
  const cards = document.querySelectorAll(".listcard");
  const btns = document.querySelectorAll(".filter-btn");

  if (valgt.classList.contains("active")) {
    valgt.classList.remove("active");
    cards.forEach((card) => { card.classList.remove("hide"); });
  } else {
    btns.forEach((btn) => { btn.classList.remove("active"); });
    valgt.classList.add("active");

    if (valgt.classList.contains("producer-btn")) {
      filterProducer(e);
    } else {
      filterGenre(e);
    }
  }
}

// Filtrering

  // Producere
  function filterProducer(e) {
  const valgtProducer = e.target.dataset.producer;
  const cards = document.querySelectorAll(".listcard");

  cards.forEach((card) => {
    if (card.dataset.producer == Palgtproducer) {
      card.classList.remove("hide");
    } else {
      card.classList.add("hide");
    }
  })

}

  // Genre
  function filterGenre(e) {
  const cards = document.querySelectorAll<HTMLElement>(".listcard");
  const valgtGenre = e.target.dataset.genre;
  cards.forEach((card) => {
    if (card.dataset.genre && JSON.parse(card.dataset.genre).includes(valgtGenre)) {
      card.classList.remove("hide");
    } else {
      card.classList.add("hide");
    }
  })
}


// Sortering
// Knapper ændrer udseende
document.querySelectorAll('.sort-btn').forEach(btn => {
  btn.addEventListener('click', sortActive );
});

function sortActive(e) {
  const valgt = e.target;
  const cards = document.querySelectorAll(".listcard");
  const btns = document.querySelectorAll(".sort-btn");

  if (valgt.classList.contains("active")) {
    valgt.classList.remove("active");
    cards.forEach((card) => { card.classList.remove("hide"); });
  } else {
    btns.forEach((btn) => { btn.classList.remove("active"); });
    valgt.classList.add("active");
    sort(e)
  }
}

// Selve sortering foregår her

function sort(e) {
  const cards = document.querySelectorAll<HTMLElement>(".listcard");
  const container = document.querySelector(".projectcontainer");
  container.textContent="";
  let newList;

  if (e.target.dataset.year) {
    const valgtDir = e.target.dataset.year;
    if (valgtDir == "acc") {
    newList = [...cards].sort((firstItem, secondItem) => firstItem.dataset.year - secondItem.dataset.year,
  );
  } else {
    newList = [...cards].sort((firstItem, secondItem) => secondItem.dataset.year - firstItem.dataset.year,
  );
  } 
  } else {
    const valgtDir = e.target.dataset.artist;
    if (valgtDir == "az") {
      newList = [...cards].sort((firstItem, secondItem) => firstItem.dataset.artist.localeCompare(secondItem.dataset.artist, "da")
  );
    } else {
      newList = [...cards].sort((firstItem, secondItem) => secondItem.dataset.artist.localeCompare(firstItem.dataset.artist, "da")
  );
    }
  }
   newList.forEach((card) => container.append(card));
}


</script>