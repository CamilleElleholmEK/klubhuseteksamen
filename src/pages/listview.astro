        <button data-genre="Garage rock" class="filter-btn genre-btn">Garage rock</button>
        <button data-genre="Hiphop" class="filter-btn genre-btn">Hiphop</button>
        <button data-genre="Indie" class="filter-btn genre-btn">Indie</button>
        <button data-genre="Indie pop" class="filter-btn genre-btn">Indie pop</button>
        <button data-genre="Indie rock" class="filter-btn genre-btn">Indie rock</button>
        <button data-genre="Jazz" class="filter-btn genre-btn">Jazz</button>
