---
import "../css/custom.css";
import "../css/general.css";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="producer-container">
    <div id="mads-moelgaard" class="producer">
      <a href="/mads"><h3>Mads Mølgaard</h3></a>
    </div>
    <div class="producer">
      <a href="/mads"><h3>Christian Afel</h3></a>
    </div>
    <div class="producer">
      <a href="/mads"><h3>Felix Ziska</h3></a>
    </div>
    <div class="producer">
      <a href="/mads"> <h3>Peter Slot</h3></a>
    </div>
  </div>
</Layout>

<style>
  body {
    background-image: var(--gradient-dark);
    background-attachment: fixed;
    min-height: 100vh;
  }
  .producer-container {
    width: 90%;
    margin: 0 auto;
    height: 90vh;
    margin-top: 5rem;
  }

  .producer {
    position: relative;
    min-height: 9rem;
    padding: 1rem auto;
    background: linear-gradient(140deg, #090401 0%, #170f08 90%);
    border-top: 1.5px solid white;
    transform: translateY(0);
    transition: transform 720ms cubic-bezier(0.075, 0.82, 0.165, 1);
  }

  .producer:hover {
    transform: translateY(-50px);
  }

  .producer-container:has(.producer:hover) .producer:not(:hover) {
    transform: translateY(4px);
  }

  .producer + .producer {
    margin-top: -4.5rem;
  }

  .producer h3 {
    color: white;
    font-size: 115px;
    margin: 0;
    filter: contrast(1.2) saturate(1.3) blur(1px);
    mix-blend-mode: screen;
    text-shadow:
      -2px 0 rgb(255, 204, 0),
      -4px 0 red,
      2px 0 rgb(0, 238, 255),
      4px 0 rgb(0, 0, 255);
  }

  .producer:first-child {
    border-top: none;
    background: transparent;
  }

  a {
    text-decoration: none;
  }
</style>
