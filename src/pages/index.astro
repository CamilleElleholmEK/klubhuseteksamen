---
import "../css/custom.css";
import "../css/general.css";
import Layout from "../layouts/Layout.astro";
import IndexCard from "../components/IndexCard.astro";
import GetInTouch from "../components/GetInTouch.astro";

---

<!-- import ProducerCard/IndexCard, hvor end du laver componenten og ryk denne op i fench<33 from '../components/ProducerCard.astro'; -->
<Layout>
  <section class="hero_section">
    <div class="hero-media">
      <h1 id="klubhuset-anim" aria-label="Klubhuset"></h1>
      <video autoplay muted loop playsinline aria-label="Atmospheric b-roll from the Klubhuset studio">
        <source src="/vids/b-roll.webm" type="video/webm" />
      </video>
    </div>
    <!-- <div class="hero-klubhuset"> -->
      <div class="herotekst">
        <h2>Music studio</h2>
        <p>Copenhagen</p>
        <a id="see-work-btn" class="ctal" href="/listview">See our work</a>
      </div>
    <!-- </div> -->
  </section>


  <section>
    <div class="what_we_do">
      <h3>WHAT WE DO</h3>

      <p>
        We are a team of producers and musicians inspired by the warmth,
        character, and unpredictability of analog recording. Using old-school
        techniques, vintage gear, and live performances, we focus on capturing
        real emotion and energy in every track. Blending classic studio
        craftsmanship with a modern creative approach, we create music that
        feels raw, honest, and timeless.
      </p>
    </div>


    <div class="wwd_img">
      <div class="wwd_img_frame wwd_img_frame_1">
        <img id="wwd_img_1" src="imgs/orgel.webp" alt="person playing organ" loading="lazy"/>
      </div>
      <div class="wwd_img_frame wwd_img_frame_2">
        <img id="wwd_img_2" src="imgs/Joakim.webp" alt="Joakim" loading="lazy"/>
      </div>
    </div>
  </section>

  <!-- Indsæt selv producer-card-component når du har den, men lad glitch-klassen stå, så h2 situationen ikke ryger :o) -->
  <section class="producer_card_view">
    <div class="who_we_are">
      <h3>WHO WE ARE</h3>
    </div>

    <div class="container">
      <ul id="cards">
        <li class="card" id="card1">
          <IndexCard
            producerNumber="#01"
            topThreeAlbum1="imgs/TheBlueVan.webp"
            topThreeAlbum2="imgs/TheSavageRose.webp"
            topThreeAlbum3="imgs/Calby.webp"
            producerImage="imgs/mads_index.webp"
            producerRole="[producer, mix and master engineer]"
            producerName="Mads Mølgaard"
            producerDescription="I'm inspired by warm analog tones, live performances, and recordings that feel timeless and alive."
            autograph="imgs/AutoMads.webp"
          />
        </li>
        <li class="card" id="card2">
          <IndexCard
            producerNumber="#02"
            topThreeAlbum1="imgs/AlbumPlaceholder.webp"
            topThreeAlbum2="imgs/AlbumPlaceholder.webp"
            topThreeAlbum3="imgs/AlbumPlaceholder.webp"
            producerImage="imgs/mads_felix.webp"
            producerRole="[producer, violonist]"
            producerName="Felix Ziska"
            producerDescription="Inspired by vintage gear, late-night sessions, and organic performances, I aim to capture music with depth, soul, and lasting character."
            autograph="imgs/AutoFelix.webp"
          />
        </li>
        <li class="card" id="card3">
          <IndexCard
            producerNumber="#03"
            topThreeAlbum1="imgs/AlbumPlaceholder.webp"
            topThreeAlbum2="imgs/AlbumPlaceholder.webp"
            topThreeAlbum3="imgs/AlbumPlaceholder.webp"
            producerImage="imgs/peter.webp"
            producerRole="[Mix and master engineer]"
            producerName="Peter Slot"
            producerDescription="Rooted in classic recording techniques and modern atmosphere, I'm inspired by performances that feel alive, unpolished, and deeply human."
            autograph="imgs/AutoPeter.webp"
          />
        </li>
        <li class="card" id="card4">
          <IndexCard
            producerNumber="#04"
            topThreeAlbum1="imgs/AlbumPlaceholder.webp"
            topThreeAlbum2="imgs/AlbumPlaceholder.webp"
            topThreeAlbum3="imgs/AlbumPlaceholder.webp"
            producerImage="imgs/Christian.webp"
            producerRole="[producer & mix-engineer]"
            producerName="Christian Afel"
            producerDescription="I love building records that breathe — combining analog color, raw emotion, and live energy into mixes that feel honest and timeless."
            autograph="imgs/AutoChristian.webp"
          />
        </li>
      </ul>
    </div>
  </section>

  <section class="contact">
    <h3>LET'S GRAB A COFFEE</h3>

    <p id="contact_text">
      Come by the studio sometime and hang out with us. We are a small team of
      producers and musicians who love making records in a relaxed, creative
      atmosphere surrounded by vintage gear, loud amps, old tape machines, and
      whatever strange ideas happen during the session. Whether it turns into
      writing, recording, experimenting, or just listening to music and talking
      for hours, the door is always open for good people, good energy, and
      honest creativity.
    </p>
       <GetInTouch />
  </section>
   
</Layout>

<style>
  html {
    height: 100%;
  }

  .herotekst h2 {
    font-size: var(--h5-size);
    font-weight: var(--book);
    line-height: 31px;
    filter: none;
    mix-blend-mode: none;
    text-shadow: none;
  }

  body {
    background-image: var(--gradient-dark);
    background-attachment: fixed;
    min-height: 100%;
  }

  section {
    margin: 0px 2vw 0px 2vw;
  }

  .hero_section {
    margin-top: 10px;
    margin-bottom: 40px;
    overflow: hidden;
  }

  .hero-media {
    position: relative;
  }

  /* VIDEO */
  .hero-media video {
    display: block;
    width: 100%;
    max-width: 100%;
    height: 90vh;
    object-fit: cover;
    margin-inline: auto;
    position: relative;
    z-index: 1;
  }

  /* LOTTIE ANIMATION */
  #klubhuset-anim {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    width: 100%;
    height: auto;
    pointer-events: none;
        filter: contrast(1.2) saturate(1.3) blur(3px);
  }

  #klubhuset-anim svg {
    width: min(45vw, 500px) !important;
    height: auto !important;
    display: block;
  }

  /* SVG Klubhuset, tekst og CTA */
  .hero-klubhuset {
    display: grid;
    /* MULIGVIS 2FR 1FR så SVG får sin plads */
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 24px;
  }

  /* Tekst + CTA */
  .herotekst {
    display: flex;
    /* grid-column: 2 / span 2; */
    flex-direction: column;
    align-items: end;
    text-align: RIGHT;
    gap: 1rem;
    margin-top: 1rem;
  }

  button {
    background-color: transparent;
    font-family: var(--stolzl);
    color: var(--secondary);
    border: none;
  }

  #see-work-btn {
    padding: 3px 6px 3px 18px;
    border-top-left-radius: 75px;
    /* margin-left: 34vw; */
    stroke: var(--secondary);
    border: solid 1px var(--secondary);
    text-decoration: none;
    color: inherit;
    display: flex;
    width: fit-content;
    justify-self: end;
  }

  #see-work-btn:active {
    background-color: transparent;
    border: solid 1px var(--primary);
    color: var(--primary);
    text-decoration: none;
  }

  #see-work-btn:hover {
    border: solid 1px var(--primary);
    color: var(--primary);
  }

  .wwd_img,
  .wwd_grafik {
    width: 50%;
    display: grid;
    margin-top: 80px;
    margin-bottom: -80px;
  }

  .wwd_img {
    position: relative;
    min-height: 700px;
  }

  .wwd_img_frame {
    position: absolute;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .wwd_img_frame_1 {
    width: 72%;
    top: 0;
    left: 0;
  }

  .wwd_img_frame_2 {
    width: 44%;
    top: 240px;
    left: 50%;
    z-index: 2;
  }

  #wwd_img_1 #wwd_img_2 {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #wwd_img_1 {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  #wwd_img_2 {
    width: 100%;
    height: 80%;
    object-fit: cover;
    object-position: 60% center;
    transform: scale(0.7);
  }
  /* skal placeret til højre både på mobil og desktop
 .wwd_grafik {
	align-items: end;
	gap: 2rem;
} */

  /* INDEX CARDS */

  :root {
    --cards: 4;
    --cardHeight: 40.5vh;
    --cardTopPadding: 7rem;
    --cardStickyStart: 10rem;
    --cardMargin: 8vw;
  }

  .container {
    width: 100%;
    margin: 0 auto;
  }

  #cards {
    list-style: none;
    padding-left: 0;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: repeat(var(--cards), var(--cardHeight));
    gap: var(--cardMargin);
    padding-bottom: calc(var(--cards) * var(--cardTopPadding));
    margin-bottom: var(--cardMargin);
  }

  #card1 {
    --index: 1;
  }

  #card2 {
    --index: 2;
  }

  #card3 {
    --index: 3;
  }

  #card4 {
    --index: 4;
  }

  .card {
    position: sticky;
    top: calc(
      var(--cardStickyStart) + ((var(--index) - 1) * var(--cardTopPadding))
    );
  }

  .contact {
    text-align: right;
  }
  #contact_text {
    max-width: 550px;
    text-align: left;
  }

  .who_we_are {
    position: sticky;
    top: 70px;
    margin-bottom: 5rem;
  }

  @media (min-width: 850px) {
    #see-work-btn:hover {
      background-color: transparent;
      border: solid 1px var(--contrast);
      color: var(--contrast);
    }

    .contact{
      margin-bottom: 90px;
      margin-top: 150px;
    }
    .contact h3 {
      text-align: right;
    }

   #contact_text{
      text-align: right;
        margin-left: auto;
        
    }

     .what_we_do{
      margin-top: 9rem;
     }

    .what_we_do h3 {
      text-align: right;
    }

    .what_we_do p {
      text-align: right;
      max-width: 62ch;
      margin-left: auto;
    }

       #klubhuset-anim {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    width: 70%;
    height: auto;
    pointer-events: none;
        filter: contrast(1.2) saturate(1.3) blur(3px);
  }

  .wwd_img,
  .wwd_grafik {
    
    margin-bottom: 40px;
  }

  
    }


    /* placering af billeder fra B-roll
	#wwd_img_1 {
		display: grid;
		grid-column: 0.75 / 4;
	} 
		
	#wwd_img_2 {
		display: grid;
		grid-column: 0.75 / 4;
	} */
  
</style>
<script is:inline src="/lottie.js"></script>
<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("klubhuset-anim");

    const animation = window.lottie?.loadAnimation({
      container,
      renderer: "svg",
      loop: false,
      autoplay: false,
      path: "/klubhuset.json",
    });

    animation?.addEventListener("DOMLoaded", () => {
      container.querySelectorAll("g[aria-label]").forEach((el) => {
        el.removeAttribute("aria-label");
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animation?.goToAndPlay(0, true);
            observer.disconnect();
          }
        });
      },
      {
        root: null,
        threshold: 0.35,
      },
    );

    if (container) observer.observe(container);
  });
</script>
