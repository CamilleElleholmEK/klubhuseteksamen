---
import "../css/custom.css"
import "../css/general.css"
import Layout from '../layouts/Layout.astro';
---
<!-- import ProducerCard/IndexCard, hvor end du laver componenten og ryk denne op i fench<33 from '../components/ProducerCard.astro'; -->

<Layout>

<section class="hero_section">
	<source src="../assets/hero.mp4" type="video/mp4" />
	<video autoplay muted loop></video>
	 <div class="hero-klubhuset">
		<!-- SVG HER I STEDET FOR IMG -->
          <img src="/img/KLUBHUSET.png" alt="Logo-placeholder" width="200" />
          <div class="herotekst">
            <h5>Music studio</h5>
            <p>Copenhagen</p>
            <button id="see-work-btn" class="ctal">See our work</button>
          </div>
        </div>
</section>

 <section class="grid_2-6">
        <div class="what_we_do">
          <div id="glitchbox">
            <h2>WHAT WE DO</h2>
			<p>WHAT WE DO</p>
			<p>WHAT WE DO</p>
          </div>
          <p>
            We are a team of producers and musicians inspired by the warmth,
            character, and unpredictability of analog recording. Using
            old-school techniques, vintage gear, and live performances, we focus
            on capturing real emotion and energy in every track. Blending
            classic studio craftsmanship with a modern creative approach, we
            create music that feels raw, honest, and timeless.
          </p>
        </div>

        <div class="wwd_img">
          <img
            id="wwd_img_1"
            src="/"
            alt="Placeholder image"
            style="border-color: red; border-width: 2px; border-style: solid"
          />
          <img
            id="wwd_img_2"
            src="/"
            alt="Placeholder image"
            style="border-color: red; border-width: 2px; border-style: solid"
          />
        </div>

        <div class="wwd_grafik">
          <img
		  id="wwd_grafik_1"
            src="/"
            alt="Placeholder image"
            style="
              border-color: turquoise;
              border-width: 2px;
              border-style: solid;
            "
          />
          <img
            id="wwd_grafik_2"
            src="/"
            alt="Placeholder image"
            style="
              border-color: turquoise;
              border-width: 2px;
              border-style: solid;
            "
          />
        </div>
      </section>

<!-- Indsæt selv producer-card-component når du har den, men lad glitch-klassen stå, så h2 situationen ikke ryger :o) -->
	  <section class="producer_card_view">
		<div class="who_we_are">
          <div id="glitchbox">
            <h2>WHO WE ARE</h2>
			<p>WHO WE ARE</p>
			<p>WHO WE ARE</p>
          </div>
		</div>
		<!-- Indsæt selv producer-card-component når du har den, men lad glitch-klassen stå, så h2 situationen ikke ryger :o) -->
        <component>Producer 1</component>
        <component>Producer 2</component>
        <component>Producer 3</component>
        <component>Producer 4</component>
      </section>

	   <section class="contact">
          <div id="glitchbox">
            <h2>LET'S GRAB A COFFEE</h2>
			<p>LET'S GRAB A COFFEE</p>
			<p>LET'S GRAB A COFFEE</p>
          </div>
        <p id="contact_text">
          Come by the studio sometime and hang out with us. We are a small team
          of producers and musicians who love making records in a relaxed,
          creative atmosphere surrounded by vintage gear, loud amps, old tape
          machines, and whatever strange ideas happen during the session.
          Whether it turns into writing, recording, experimenting, or just
          listening to music and talking for hours, the door is always open for
          good people, good energy, and honest creativity.
        </p>
    
      </section>
</Layout>

<style>
 html {
    height: 100%;
  }
  
  body {
    background-image: var(--gradient-dark);
    background-attachment: fixed;
    min-height: 100%;
	  }

   section {
    margin: 0px 5vw 0px 5vw;
   }
   
   .hero_section {
   margin-top: 40px;
   margin-bottom: 40px;
   
   }

   /* SVG Klubhuset, tekst og CTA */
.hero-klubhuset{
	display: grid;
	/* MULIGVIS 2FR 1FR så SVG får sin plads */
	grid-template-columns: 1fr 1fr;
	gap:1rem;
}

/* Tekst + CTA */
.herotekst {
  display: flex;
  grid-column: 2 / span 2;
  flex-direction: column;
  justify-content: right;
  text-align: RIGHT;
  gap: 1rem;
}
  
   button {
   background-color: transparent;
   font-family: var(--stolzl);
   color: var(--secondary);
   border: none;
   }
		   
   #see-work-btn { 
	padding: 3px 6px 3px 18px;
	border-top-left-radius: 75px;
	margin-left: 12vw;
	stroke: var(--secondary);
	border: solid 1px var(--secondary);
   	}	

   #see-work-btn:active {
	   background-color: transparent;
	   border: solid 1px var(--primary);
	   color: var(--primary);
   } 
   
/* What we do effekt, WHO WE ARE, Grab a coffee */
#glitchbox {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: 1fr;
    }

    #glitchbox h2, #glitchbox p{
        font-family: var(--gopher);
        font-size: var(--h2-size);
        font-weight: var(--bold);
        line-height: 85px;
        mix-blend-mode: screen;
        grid-row: 1/3;
        grid-column: 1/6;
    }

    #glitchbox h2:nth-child(1) {
        color: #f00;
        filter: blur(1.5px);
        mix-blend-mode: lighten;
    }

    #glitchbox p:nth-child(2) {
        color: #00fd00;
        mix-blend-mode: screen;
        filter: blur(4px);
        padding-left: 3px;
    }

    #glitchbox p:nth-child(3) {
        color: #0000ff;
        filter: blur(1.5px);
        mix-blend-mode: lighten;
        padding-left: 6px;
    }

	.wwd_img, .wwd_grafik {
	width: 50%;
	display: grid;
	margin-top: 40px;
   margin-bottom: 40px;
}
 /* skal placeret til højre både på mobil og desktop
 .wwd_grafik {
	align-items: end;
	gap: 2rem;
} */

.contact {
	text-align: right;
	}
#contact_text {
	max-width: 550px;
	text-align: left;
}

@media (min-width: 850px) {
	
	#see-work-btn:hover {
		background-color: transparent;
		border: solid 1px var(--contrast);
		color: var(--contrast);
	}
	
    #glitchbox h2, #glitchbox p{
		font-size: var(--h2-size-desk);
		line-height: 200px;
		font-weight: var(--medium);
    }
	
	.grid_2-6 {
		display: grid;
		grid-template-columns: repeat(2, 6fr);
		gap: 1rem;
	} 
	/* H2 + paragraph - overvejer at flytte What We do op over grid_2-6 og tilføje class "what_we_do" så vi kan style sådan samtidig med, at det står på samme linje??*/
	.what_we_do, .who_we_are, .contact {
		display: flex;
		grid-column: 2 / span 2;
		flex-direction: column;
		justify-content: left;
		text-align: left;
		gap: 1rem;
	}
	
	.contact {
		text-align: right;
		align-items: end;}
	
	.contact_text {
		max-width: 550px;
		text-align: left;
	}

	
	/* placering af billeder fra B-roll
	#wwd_img_1 {
		display: grid;
		grid-column: 0.75 / 4;
	} 
		
	#wwd_img_2 {
		display: grid;
		grid-column: 0.75 / 4;
	} */



   }
</style>