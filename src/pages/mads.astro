---
import "../css/custom.css";
import "../css/general.css";

import ProducerLayout from "../layouts/ProducerLayout.astro";
import MicroLeft from "../components/MicroLeft.astro";
import MicroRight from "../components/MicroRight.astro";
import GetInTouch from "../components/GetInTouch.astro";
---

<ProducerLayout>
  <section id="section1">
    <div class="imgh1">
      <div class="imgwrap">
        <img src="/imgs/mads_index.webp" alt="Mads Mølgaard" />
      </div>
      <h1>Mads</h1>
    </div>

    <h1 class="lastname">Mølgaard</h1>
    <MicroLeft title="[We like it here]" />
    <div class="textgraphic">
      <img src="/imgs/sliceBtmLeft.svg" alt="Graphic element" />
      <p>[Mix & Mastering Engineer]</p>
    </div>
    <p id="intromobile">
      I’m Mads. Drawn to imperfect sounds, tape texture, loud rooms, and records
      that feel alive. I love productions that are messy, emotional, and full of
      atmosphere.
    </p>
    <h2 id="introdesk">
      <span id="introspan">.</span>I’m Mads. Drawn to imperfect sounds, tape
      texture, loud rooms, and records that feel alive. I love productions that
      are messy, emotional, and full of atmosphere.
    </h2>
    <MicroLeft title="Vibes" />
  </section>
  <section id="section2">
    <div id="section2_1">
      <MicroLeft title="[Texture before polish]" />
      <h3>Selected works</h3>
    </div>
    <div id="section2_2">
      <div>
        <MicroLeft title="Warmth" />
      </div>
      <!-- Olli indsæt billeder ved siden af accordion her -->
      <div class="collage">
        <img src="/imgs/bluevan.webp" alt="The Blue Van band" />
        <img
          id="collagetop"
          src="/imgs/calby_album.webp"
          alt="While I Wait album"
        />
      </div>
      <div class="accordionwrap">
        <button data-target="accordion1" class="accordion">The Blue Van</button>
        <div data-panel="accordion1" class="panel" hidden>
          <div class="accordiontitle">
            <p>[Roles]</p>
            <p>Producer & Engineer</p>
          </div>
          <div class="accordiontext">
            <p>
              Working with The Blue Van has been one of my favorite creative
              experiences. Their analog spirit and live energy reflect a lot of
              what I love about production in general — records with
              personality, movement, and human imperfections.
            </p>
            <p>
              The productions I connect with most are the ones that prioritize
              feeling over perfection. I love music that sounds instinctive,
              emotional, and full of character.
            </p>
            <a href="/details/Would You Change Your Life?">Read more</a>
          </div>
        </div>

        <button data-target="accordion2" class="accordion">Calby</button>
        <div data-panel="accordion2" class="panel" hidden>
          <div class="accordiontitle">
            <p>[Roles]</p>
            <p>Producer & Engineer</p>
          </div>
          <div class="accordiontext">
            <p>
              Working with The Blue Van has been one of my favorite creative
              experiences. Their analog spirit and live energy reflect a lot of
              what I love about production in general — records with
              personality, movement, and human imperfections.
            </p>
            <p>
              The productions I connect with most are the ones that prioritize
              feeling over perfection. I love music that sounds instinctive,
              emotional, and full of character.
            </p>
            <a href="/details/Inner Critic's Choice Awards">Read more</a>
          </div>
        </div>

        <button data-target="accordion3" class="accordion">MØ</button>
        <div data-panel="accordion3" class="panel" hidden>
          <div class="accordiontitle">
            <p>[Roles]</p>
            <p>Producer & Engineer</p>
          </div>
          <div class="accordiontext">
            <p>
              Working with The Blue Van has been one of my favorite creative
              experiences. Their analog spirit and live energy reflect a lot of
              what I love about production in general — records with
              personality, movement, and human imperfections.
            </p>
            <p>
              The productions I connect with most are the ones that prioritize
              feeling over perfection. I love music that sounds instinctive,
              emotional, and full of character.
            </p>
            <a href="/details/Plæygirl">Read more</a>
          </div>
        </div>
      </div>
    </div>
    <MicroRight title="[Texture before polish]" />
  </section>

  <section id="section3">
    <MicroRight title="Warmth" />
    <h3>MY APPROACH</h3>
    <div id="section3_1">
      <div class="approach">
        <p>
          My approach to production is centered around emotion, energy, and
          atmosphere. I’m less interested in perfection and more interested in
          capturing something that feels alive and honest. I love working with
          texture, movement, and imperfections — the details that give a record
          personality and make it feel human.
        </p>
        <p>
          Whether the process is loud and chaotic or stripped back and intimate,
          I always focus on creating an environment where ideas can happen
          naturally and where the emotion of the music stays at the center
        </p>
      </div>
      <a href="/listview">See my work</a>
    </div>
    <div class="video-wrap">
      <iframe
        width="560"
        height="315"
        src="https://www.youtube.com/embed/i48EUOKxFOI?si=mL8vXnKpRdX8ePPu&controls=0"
        title="YouTube video player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen></iframe>
    </div>
  </section>
  <section id="section4">
    <GetInTouch />
    <p id="dontwait">
      <span id="section4span">.</span>You don’t have to wait for perfect - Let’s
      Talk
    </p>
    <div>
      <a href="tel:+4512345678">+45 12 34 56 78</a>
      <a href="">Mail</a>
      <a
        href="https://www.instagram.com/mads_mol/"
        target="_blank"
        rel="noopener noreferrer">Instagram</a
      >
      <a
        href="https://www.discogs.com/artist/876484-Mads-M%C3%B8lgaard-Helb%C3%A6k?srsltid=AfmBOoprQmjjr917QdMPt6yyyanaYJongpcANJKDedF57ICRbhLiuFHN"
        target="_blank"
        rel="noopener noreferrer">Discogs</a
      >
    </div>
  </section>
</ProducerLayout>

<style>
  html {
    height: 100%;
  }

  body {
    margin-top: 128px;
    background-color: #0b0501;
    background-image: url("/imgs/producergraphic.svg"), var(--gradient-dark);
    /* background-position: left top 80%, center; */
    background-attachment: scroll, fixed;
    background-size: 100%, 100%;
    min-height: 100%;
    background-repeat: no-repeat;
  }

  section {
    width: 95vw;
    margin: 0 auto;
  }

  #section1 p:nth-child(2) {
    color: var(--contrast);
  }

  #section1 h1:nth-child(1) {
    margin-bottom: 64px;
  }

  .imgwrap {
    width: 90vw;
    height: 100vw;
    margin: 0 auto;
    margin-bottom: 64px;
  }

  #section4 div p:hover,
  #section4 div a:hover {
    color: var(--contrast);
  }

  .imgwrap img {
    object-fit: cover;
    width: 100%;
    height: 100%;
    object-position: 90% 100%;
  }

  .textgraphic {
    display: flex;
    margin-top: 64px;
    margin-bottom: 16px;
  }

  .textgraphic img {
    width: 12px;
    height: 11px;
    margin-right: 12px;
  }

  #introdesk {
    display: none;
    font-size: var(--h4-size);
    font-weight: var(--book);
    line-height: 52px;
    letter-spacing: -3%;
    filter: none;
    mix-blend-mode: none;
    text-shadow: none;
  }

  #intromobile {
    max-width: 45ch;
    margin-bottom: 32px;
  }

  #section2_1 {
    margin-bottom: 16px;
  }

  .accordion {
    background-color: transparent;
    border: none;
    border-top: solid 1px var(--secondary);
    color: var(--secondary);
    cursor: pointer;
    padding: 16px 0px;
    width: 100%;
    text-align: left;
    font-size: var(--h5-size);
    font-weight: var(--book);
    line-height: 31px;
    /* Fjerner den browser specifikke blå farve ved klik */
    -webkit-appearance: none;
    -webkit-tap-highlight-color: transparent;
    appearance: none;
    outline: none;
  }

  .accordion:hover {
    color: var(--contrast);
  }

  .accordionwrap {
    border-bottom: solid 1px var(--secondary);
  }

  .panel {
    padding: 0 18px;
    background-color: transparent;
  }

  .panel a {
    margin-top: 16px;
  }

  .panel a,
  #section3 a {
    background-color: transparent;
    font-family: var(--stolzl);
    color: var(--secondary);
    border: solid 1px var(--secondary);
    padding: 3px 18px 3px 6px;
    border-top-right-radius: 75px;
    text-decoration: none;
    margin-bottom: 32px;
    display: inline-block;
  }

  .panel a:hover,
  #section3 a:hover {
    border-color: var(--contrast);
    color: var(--contrast);
  }

  .accordiontitle {
    display: flex;
    margin-bottom: 32px;
  }

  .accordiontitle p:nth-child(1) {
    margin-right: 50px;
    color: var(--contrast);
  }

  .accordiontext p {
    max-width: 40ch;
    margin-bottom: 16px;
  }

  #section3 p {
    max-width: 62ch;
    margin-top: 16px;
  }

  #section3 a {
    margin-top: 16px;
  }

  #section3 {
    margin-top: 64px;
  }

  .video-wrap {
    width: 100%;
    aspect-ratio: 1920/800;
  }

  .video-wrap iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .collage {
    width: 70vw;
    position: relative;
    height: 70vw;
    overflow: visible;
    margin-bottom: 16px;
  }

  .collage img:nth-child(1) {
    object-fit: fill;
    width: 100%;
    height: 100%;
  }

  #collagetop {
    display: none;
  }

  .activebtn {
    color: var(--contrast);
    border-bottom: none;
  }

  #section4span {
    color: transparent;
    padding-right: 10px;
  }

  #dontwait {
    width: 12ch;
  }

  #section4 div {
    display: flex;
    flex-direction: column;
    align-items: end;
    text-transform: uppercase;
    color: var(--secondary);
    text-decoration: underline;
    margin-top: 100px;
    margin-bottom: 100px;
  }

  #section4 a {
    color: var(--secondary);
    font-weight: 300;
    margin-top: 32px;
  }

  @media (min-width: 850px) {
    .imgwrap {
      width: 36vw;
      height: 46vw;
      margin: 0;
    }

    .imgwrap img {
      object-fit: cover;
      width: 100%;
      height: 100%;
      object-position: 75% 100%;
    }

    .imgh1 {
      display: flex;
      justify-content: space-between;
      align-items: end;
    }
    .imgh1 h1 {
      order: -1;
    }

    .lastname {
      margin-bottom: 90px;
      overflow-wrap: break-word;
    }

    #introspan {
      padding-right: 20vw;
      color: transparent;
    }

    #intromobile {
      display: none;
    }

    #introdesk {
      display: block;
    }

    .textgraphic {
      margin-bottom: 24px;
      margin-top: 90px;
    }

    #section2_1 {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 190px;
    }

    .collage {
      width: 22vw;
      height: 22vw;
      margin-right: 45px;
    }

    #collagetop {
      display: block;
      position: absolute;
      top: 80%;
      left: 80%;
      transform: translate(-20%, -20%);
      width: 70%;
    }

    #section2_2 {
      margin-top: 32px;
      display: flex;
      justify-content: space-between;
    }

    #section2_2 div:nth-child(1) {
      align-items: center;
      display: flex;
    }

    .accordionwrap {
      width: 45vw;
      height: fit-content;
    }

    #section3_1 {
      display: flex;
      justify-content: space-between;
      align-items: end;
    }

    #section3_1 div p {
      max-width: 60ch;
    }

    #section3_1 div p:nth-child(2) {
      margin-top: 0;
    }

    #section3_1 a {
      border-top-left-radius: 75px;
      border-top-right-radius: 0px;
      padding: 3px 6px 3px 18px;
    }

    #section3 {
      margin-top: 190px;
    }

    #dontwait {
      font-weight: var(--book);
      line-height: 52px;
      letter-spacing: -3%;
      font-size: var(--h4-size);
    }

    #section4 div {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>

<script>
  // @ts-nocheck
  const toggles = document.querySelectorAll<HTMLElement>(".accordion");
  const panels = document.querySelectorAll<HTMLElement>(".panel");

  // Viser og skjuler accordionpaneler
  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const target = toggle.dataset.target;
      const targetPanel = [...panels].find((p) => p.dataset.panel === target);

      panels.forEach((p) => {
        if (p.dataset.panel !== target) p.hidden = true;
      });
      // Fjern active fra andre toggles
      toggles.forEach((t) => {
        if (t !== toggle) t.classList.remove("activebtn");
      });

      targetPanel.hidden = !targetPanel.hidden;
      toggle.classList.toggle("activebtn", !targetPanel.hidden);
    });
  });
</script>
