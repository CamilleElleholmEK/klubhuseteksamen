<style>
 html {
    height: 100%;
  }
  
  body {
    background-image: var(--gradient-dark);
    background-attachment: fixed;
    min-height: 100%;
  }

  .micro {
    display: none;
  }

  section {
    width: 98vw;
    margin: 0 auto;
  }

  #section1 p:nth-child(2) {
    color: var(--contrast);
  }

  #section1 h1:nth-child(1) {
    margin-bottom: 64px;
  }

.imgwrap {
    width: 90vw;
    margin: 0 auto;
    margin-bottom: 64px;
}

.textgraphic {
    display: flex;
    margin-top: 64px;
    margin-bottom: 16px;
}

.textgraphic img {
  width: 12px;
  height: 11px;
  margin-right: 12px;
}

.accordion {
  background-color: transparent;
  border: none;
  border-top: solid 1px var(--secondary);
  color: var(--secondary);
  cursor: pointer;
  padding: 16px 0px;
  width: 100%;
  text-align: left;
  font-size: var(--h5-size);
  font-weight: var(--book);
  line-height: 31px;
  /* Fjerner den browser specifikke blå farve ved klik */
  -webkit-appearance: none;
  -webkit-tap-highlight-color: transparent;
  appearance: none;
  outline: none;
}

.accordion:hover {
    color: var(--contrast);
}

.accordionwrap {
    border-bottom: solid 1px var(--secondary);
}

.panel {
  padding: 0 18px;
  background-color: transparent;
  
}

.panel a, #section3 a {
    background-color: transparent;
    font-family: var(--stolzl);
    color: var(--secondary);
    border: solid 1px var(--secondary);
    padding: 3px 18px 3px 6px;
    border-top-right-radius: 75px;
    text-decoration: none;
    margin-bottom: 32px;
    display: inline-block;
}

.accordiontitle {
    display: flex;
    margin-bottom: 32px;
}

.accordiontitle p:nth-child(1) {
    margin-right: 50px;
    color: var(--contrast);
}

.accordiontext p,  {
    max-width: 40ch;
    margin-bottom: 16px;
}

#section3 p {
    max-width: 50ch;
    margin-top: 16px;
}

#section3 a {
    margin-top: 16px;
}

/* Olli style billeder ved siden af accordion her */
.collage {

}
/* Og her */
.collage img {

}

.activebtn {
    color: var(--contrast);
    border-bottom: none;
}


</style>

<script>
    // @ts-nocheck
  const toggles = document.querySelectorAll<HTMLElement>(".accordion");
  const panels = document.querySelectorAll<HTMLElement>(".panel");

    // Viser og skjuler accordionpaneler
    toggles.forEach(toggle => {
    toggle.addEventListener("click", () => {
    const target = toggle.dataset.target;
    const targetPanel = [...panels].find(p => p.dataset.panel === target);

    panels.forEach(p => {
      if (p.dataset.panel !== target) p.hidden = true;
    });
    // Fjern active fra andre toggles
    toggles.forEach(t => { if (t !== toggle) t.classList.remove("activebtn") });

    targetPanel.hidden = !targetPanel.hidden;
    toggle.classList.toggle("activebtn", !targetPanel.hidden);
   });
   });
</script>