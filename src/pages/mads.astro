<style>
 html {
    height: 100%;
  }
  
  body {
    background-image: url("/imgs/producergraphic.svg"), var(--gradient-dark);
    /* background-position: left top 80%, center; */
    background-attachment: scroll, fixed;
    background-size: 100%, 100%;
    min-height: 100%;
    background-repeat: no-repeat;
  }

  .micro {
    display: none;
  }

  section {
    width: 95vw;
    margin: 0 auto;
  }

  #section1 p:nth-child(2) {
    color: var(--contrast);
  }

  #section1 h1:nth-child(1) {
    margin-bottom: 64px;
  }

.imgwrap {
    width: 90vw;
    height: 100vw;
    margin: 0 auto;
    margin-bottom: 64px;
}

.imgwrap img {
object-fit: cover;
width: 100%;
height: 100%;
object-position: 90% 100%;
}

.textgraphic {
    display: flex;
    margin-top: 64px;
    margin-bottom: 16px;
}

.textgraphic img {
  width: 12px;
  height: 11px;
  margin-right: 12px;
}

#introdesk {
  display: none;
}

#intromobile {
  max-width: 45ch;
  margin-bottom: 32px;
}

#section2_1 {
  margin-bottom: 16px;
}

.accordion {
  background-color: transparent;
  border: none;
  border-top: solid 1px var(--secondary);
  color: var(--secondary);
  cursor: pointer;
  padding: 16px 0px;
  width: 100%;
  text-align: left;
  font-size: var(--h5-size);
  font-weight: var(--book);
  line-height: 31px;
  /* Fjerner den browser specifikke blå farve ved klik */
  -webkit-appearance: none;
  -webkit-tap-highlight-color: transparent;
  appearance: none;
  outline: none;
}

.accordion:hover {
    color: var(--contrast);
}

.accordionwrap {
    border-bottom: solid 1px var(--secondary);
}

.panel {
  padding: 0 18px;
  background-color: transparent;
}

.panel a {
  margin-top: 16px;
}

.panel a, #section3 a {
    background-color: transparent;
    font-family: var(--stolzl);
    color: var(--secondary);
    border: solid 1px var(--secondary);
    padding: 3px 18px 3px 6px;
    border-top-right-radius: 75px;
    text-decoration: none;
    margin-bottom: 32px;
    display: inline-block;
}

.panel a:hover, #section3 a:hover {
  border-color: var(--contrast);
  color: var(--contrast);
}

.accordiontitle {
    display: flex;
    margin-bottom: 32px;
}

.accordiontitle p:nth-child(1) {
    margin-right: 50px;
    color: var(--contrast);
}

.accordiontext p,  {
    max-width: 40ch;
    margin-bottom: 16px;
}

#section3 p {
    max-width: 50ch;
    margin-top: 16px;
}

#section3 a {
    margin-top: 16px;
}

#section3 {
  margin-top: 64px;
}

/* Olli style billeder ved siden af accordion her */
.collage {
width: 70vw;
position: relative;
height: 90vw;
overflow: visible;
margin-bottom: 16px;
}
/* Og her */
.collage img:nth-child(1) {
object-fit: fill;
width: 100%;
height: 100%;
}

#collagetop {
  display: none;
}

.activebtn {
    color: var(--contrast);
    border-bottom: none;
}

#section4span {
  color: transparent;
  padding-right: 10px;
}

#dontwait {
  width: 12ch;
}

#section4 div {
  display: flex;
  flex-direction: column;
  align-items: end;
  text-transform: uppercase;
  color: var(--secondary);
  text-decoration: underline;
  margin-top: 100px;
  margin-bottom: 100px;
}

#section4 a {
  color: var(--secondary);
  font-weight: 300;
  margin-top: 32px;
}

@media (min-width: 850px) {

  .micro {
    display: block;
    font-size: 11px;
  }

  .imgwrap {
    width: 36vw;
    height: 46vw;
    margin: 0;
  }

 .imgwrap img {
   object-fit: cover;
   width: 100%;
   height: 100%;
   object-position: 75% 100%;
  }

  .imgh1 {
    display: flex;
    justify-content: space-between;
    align-items: end;
  }
  .imgh1 h1 {
    order: -1;
  }

  .lastname {
    margin-bottom: 90px;
  }

  #introspan {
    padding-right: 20vw;
    color: transparent;
  }

  #intromobile {
    display: none;
  }

  #introdesk {
    display: block;
  }

  .textgraphic {
    margin-bottom: 24px;
    margin-top: 90px;
  }

  #section2_1 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 190px;
  }

  .collage {
   width: 20vw;
   height: 25vw;
  } 

  #collagetop {
    display: block;
    position: absolute;
    top: 80%;
    left: 80%;
    transform: translate(-20%, -20%);
    width: 70%;
}

#section2_2 {
  margin-top: 32px;
  display: flex;
  justify-content: space-between;
}

.accordionwrap {
  width: 50vw;
  height: fit-content;
}

#section3_1 {
  display: flex;
  justify-content: space-between;
  align-items: end;
}

#section3_1 div p {
  max-width: 60ch;
}

#section3_1 div p:nth-child(2) {
margin-top: 0;
}

#section3_1 a {
  border-top-left-radius: 75px;
  border-top-right-radius: 0px;
  padding: 3px 6px 3px 18px;
}

#section3 {
  margin-top: 190px;
}

#dontwait {
  font-weight: var(--book);
  line-height: 52px;
  letter-spacing: -3%;
  font-size: var(--h4-size);
}

#section4 div {
  flex-direction: row;
  justify-content: space-between;
}

}

</style>

<script>
    // @ts-nocheck
  const toggles = document.querySelectorAll<HTMLElement>(".accordion");
  const panels = document.querySelectorAll<HTMLElement>(".panel");

    // Viser og skjuler accordionpaneler
    toggles.forEach(toggle => {
    toggle.addEventListener("click", () => {
    const target = toggle.dataset.target;
    const targetPanel = [...panels].find(p => p.dataset.panel === target);

    panels.forEach(p => {
      if (p.dataset.panel !== target) p.hidden = true;
    });
    // Fjern active fra andre toggles
    toggles.forEach(t => { if (t !== toggle) t.classList.remove("activebtn") });

    targetPanel.hidden = !targetPanel.hidden;
    toggle.classList.toggle("activebtn", !targetPanel.hidden);
   });
   });
</script>