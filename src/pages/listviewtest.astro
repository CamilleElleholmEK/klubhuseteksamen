<style>
  html {
    height: 100%;
  }
  
  body {
    margin-top: 128px;
    background-image: var(--gradient-dark);
    background-attachment: fixed;
    min-height: 100%;
  }

   section {
    margin: 0px 5vw 0px 5vw;
   }

   .topsection {
    margin-top: 40px;
    margin-bottom: 20px;
   }

   #glitchbox {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: 1fr;
    }

    /* #glitchbox h1, #glitchbox p{
        font-family: var(--gopher);
        font-size: var(--h1-size);
        font-weight: var(--bold);
        line-height: 85px;
        mix-blend-mode: screen;
        grid-row: 1/2;
        grid-column: 1/2;
    }

    #glitchbox h1:nth-child(1) {
        color: #f00;
        filter: blur(1.5px);
        mix-blend-mode: lighten;
    }

    #glitchbox p:nth-child(2) {
        color: #00fd00;
        mix-blend-mode: screen;
        filter: blur(4px);
        padding-left: 3px;
    }

    #glitchbox p:nth-child(3) {
        color: #0000ff;
        filter: blur(1.5px);
        mix-blend-mode: lighten;
        padding-left: 6px;
    } */


   button, #to-top {
    background-color: transparent;
    font-family: var(--stolzl);
    color: var(--secondary);
    border: none;
    text-decoration: none;
   }

   button:hover, #to-top:hover {
    color: var(--contrast);
   }

   button:hover svg, #to-top:hover svg {
    stroke: var(--contrast);
   }

   #sort:hover, #to-top:hover {
    border-color: var(--contrast);
   }

   #sort, .filter-btn, .sort-btn, #to-top {
    border: solid 1px var(--secondary);
   }

   .filter-btn, .sort-btn {
    padding: 3px 18px 3px 6px;
    border-top-right-radius: 75px;
   }

   #sort, #to-top {
    padding: 3px 6px 3px 18px;
    border-top-left-radius: 75px;
   }

   #sort svg {
    margin-left: 12vw;
   }

   .active {
    background-color: var(--contrast);
    border: solid 1px var(--contrast);
    stroke: var(--contrast);
   }

   svg {
    stroke: var(--secondary);
   }

   .activebtn svg {
    stroke: var(--contrast);
   }

   .activebtn {
    color: var(--contrast);
   }

   #sort.activebtn {
    border-color: var(--contrast) !important;
   }

   .filterbar {
    border-bottom: solid 0.5px var(--secondary);
    display: flex;
    justify-content: space-between;
    padding: 8px 0px;
    margin: 20px 0px 8px 0px;
   }

   .filterbar div button {
    padding: 3px 6px 3px 0px;
   }

   .filterbar div button:nth-child(2) {
    border-right: solid 1px var(--secondary);
    border-left: solid 1px var(--secondary);
    padding-left: 6px;
   }

   /* .filter-content {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr 1fr;
   } */

   .filter-btn {
    margin: 2px;
   }

   .projectcontainer {
    margin-bottom: 40px;
   }

   @media (min-width: 850px) {
    .projectcontainer {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      border-top: solid 0.5px var(--secondary);
      padding-top: 15px;
      padding-bottom: 15px;
      background: linear-gradient(to right, transparent 0%, transparent 49.9%, var(--secondary) 50%, transparent 50.1%);
    }

    .project {
      padding: 16px;
    }

    #glitchbox h1, #glitchbox p{
       font-size: var(--h1-size-desk);
       line-height: 200px;
       font-weight: var(--medium);
    }
   }
</style>

<script>
  // @ts-nocheck

  // Viser og skjuler filtreringspaneler
  const toggles = document.querySelectorAll<HTMLElement>(".filter-toggle");
  const panels = document.querySelectorAll<HTMLElement>(".filter-content");
  const svg = document.querySelectorAll<HTMLElement>(".svg")
  

  toggles.forEach(toggle => {
  toggle.addEventListener("click", () => {
    const target = toggle.dataset.target;
    const targetPanel = [...panels].find(p => p.dataset.panel === target);

    panels.forEach(p => {
      if (p.dataset.panel !== target) p.hidden = true;
    });
    // Fjern active fra andre toggles
    toggles.forEach(t => { if (t !== toggle) t.classList.remove("activebtn") });

    targetPanel.hidden = !targetPanel.hidden;
    toggle.classList.toggle("activebtn", !targetPanel.hidden);
   });
   });

  //  Stackable filtrering
  const aktiveProducere = [];
  const aktiveGenrer = [];

  document.querySelectorAll(".filter-btn").forEach(btn => {
    btn.addEventListener("click", (e) => {
      const valgt = e.target;
      // Tjekker om det er en producerknap der er trykket på
      const erProducer = valgt.classList.contains("producer-btn");
      // En kompakt if/else. aktivtArray = aktiveProducere hvis erProducer er true, ellers aktivtArray = aktiveGenrer
      const aktivtArray = erProducer ? aktiveProducere : aktiveGenrer;
      // value = knappens producer data hvis erProducer er true, ellers value = knappens genre data
      const value = erProducer ? valgt.dataset.producer : valgt.dataset.genre;

      // finder hvor i det aktive array value'en er
      const index = aktivtArray.indexOf(value);
      if (index === -1) {
        // Ikke aktiv endnu – tilføj til arrayet og tilføj active
        aktivtArray.push(value);
        valgt.classList.add("active");
      } else {
        // Allerede aktiv – fjern fra arrayet og fjern active
        aktivtArray.splice(index, 1);
        valgt.classList.remove("active");
      }

      anvendFiltre();
    });
  });

  // Filtrerer alle cards efter indholdet af de to filter arrays
  function anvendFiltre() {
    const cards = document.querySelectorAll(".listcard");

     cards.forEach(card => {
      // Producer-tjek: hvis ingen producere er valgt (længde på arrayet=0), vil producerMatch være true på alle cards
      // producerMatch er true hvis aktiveProducere arrayet indeholder kortets producer
      const producerMatch =
        aktiveProducere.length === 0 ||
        aktiveProducere.includes(card.dataset.producer);

      // Genre-tjek: hvis ingen genrer er valgt (længde på arrayet=0), vil genreMatch være true på alle cards
      // Et card matcher hvis mindst ét af cardets genrer er i aktiveGenrer arrayet
      const cardGenrer = JSON.parse(card.dataset.genre || "[]");
      const genreMatch =
        aktiveGenrer.length === 0 ||
        aktiveGenrer.some(g => cardGenrer.includes(g));

        // Begge skal passe, ellers tilføjes "hide"
      if (producerMatch && genreMatch) {
        card.classList.remove("hide");
      } else {
        card.classList.add("hide");
      }
    });

  }

  // Sortering

  document.querySelectorAll('.sort-btn').forEach(btn => {
    btn.addEventListener('click', sortActive);
  });

  function sortActive(e) {
  const valgt = e.target;
  const btns = document.querySelectorAll(".sort-btn");

  if (valgt.classList.contains("active")) {
    valgt.classList.remove("active");
    // Gendan rækkefølge ved at køre filtrering igen uden at røre hide-klasser
    genopretRækkefølge();
  } else {
    btns.forEach(btn => btn.classList.remove("active"));
    valgt.classList.add("active");
    sort(e);
  }
}

function sort(e) {
  const cards = document.querySelectorAll(".listcard");
  const container = document.querySelector(".projectcontainer");
  let newList;

  if (e.target.dataset.year) {
    const valgtDir = e.target.dataset.year;
    if (valgtDir == "acc") {
      newList = [...cards].sort((a, b) => a.dataset.year - b.dataset.year);
    } else {
      newList = [...cards].sort((a, b) => b.dataset.year - a.dataset.year);
    }
  } else {
    const valgtDir = e.target.dataset.artist;
    if (valgtDir == "az") {
      newList = [...cards].sort((a, b) => a.dataset.artist.localeCompare(b.dataset.artist, "da"));
    } else {
      newList = [...cards].sort((a, b) => b.dataset.artist.localeCompare(a.dataset.artist, "da"));
    }
  }

  // Tilføj cards i ny rækkefølge – hide-klasser røres ikke
  newList.forEach(card => container.append(card));
}
    
// Sorterer a-z hvis alle sorteringsknapper er slået fra. anvendFiltre kaldes som sikekrhedsnet
function genopretRækkefølge() {
  const cards = document.querySelectorAll(".listcard");
  const container = document.querySelector(".projectcontainer");
  [...cards]
    .sort((a, b) => a.dataset.artist.localeCompare(b.dataset.artist, "da"))
    .forEach(card => container.append(card));
  anvendFiltre();
}

</script>