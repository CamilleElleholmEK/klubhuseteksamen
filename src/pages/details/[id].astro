---
// @ts-nocheck
import "../../css/custom.css"
import "../../css/general.css"
import Layout from "../../layouts/Layout.astro"
import ArtistLayout from "../../layouts/ArtistLayout.astro"
import ListCard from "../../components/ListCard.astro"

export async function getStaticPaths() {
  const endpoint =
    "https://cslftqskycbszssbrjfq.supabase.co/rest/v1/artister?select=*";

  const options = {
    headers: { apikey: "sb_publishable_uJBiElMI8evEQetR2TtT2g_2o4KGmfP" },
  };
  const response = await fetch(endpoint, options);
  const data = await response.json();

  return data.map((project) => {
    return {
      params: { id: project.titel_album },
      props: { project },
    };
  });
}

const { id } = Astro.params;
const { project } = Astro.props;

// Hent albums med samme genre (ekskluder det nuværende)
const res = await fetch(
  `https://cslftqskycbszssbrjfq.supabase.co/rest/v1/artister?select=*`,
  { headers: { apikey: "sb_publishable_uJBiElMI8evEQetR2TtT2g_2o4KGmfP" } }
);
const allAlbums = await res.json();

const related = allAlbums
  .filter(a => a.titel_album !== project.titel_album)
  .filter(a => a.genre?.includes(project.genre[0]))
  .slice(0, 2);
  
---

<ArtistLayout>
<section id="topsection">
<div id="outer">
    <div id="spotifywrapper">
    <img src={project.albumcover.replace(/^"|"$/g, '')} />
    <iframe data-testid="embed-iframe" style="border-radius:12px" src={project.spotify.replace(/^"|"$/g, '')} width="100%" height="152" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
    </div>
    <div id="inner">
        <div id="glitchbox">
         <h1>{project.titel_album}</h1>
         <p>{project.titel_album}</p>
         <p>{project.titel_album}</p>
        </div>
        <h5>{project.artist}</h5>
        <h6>{project.year}</h6>
        <div id="details">
            <div id="genre">
                <h6>Genre:</h6>
                <p class="cap2">{project.genre.join(', ')}</p>
            </div>
            <div id="about">
                <h6>About</h6>
                <div id="aboutlists">
                    <div id="list1">
                        <p class="cap2">Producer</p>
                        <p class="cap2">Engineer</p>
                        <p class="cap2">Label</p>
                        <p class="cap2">Accolades</p>
                    </div>
                    <div id="list2">
                        <p class="cap2">Mads Mølgaard</p>
                        <p class="cap2">Mads Mølgaard</p>
                        <p class="cap2">Sony</p>
                        <p class="cap2">DMA</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</section>
<section id="bottomsection">
<div id="samegenre">
    <a href="/">{project.genre[0]}</a>
    <h2>Same genre</h2>
    {related.map((project) => <ListCard {project} />)}
</div>
</section>
</ArtistLayout>

<style>
   body {
        background-color: var(--dark4);
    }

    img {
        width: 300px;
    }
    #glitchbox {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: 1fr;
    }

    #glitchbox h1, #glitchbox p{
        text-transform: uppercase;
        letter-spacing: -3.45px;
        font-size: 115px;
        line-height: 105px;
        font-family: var(--gopher);
        mix-blend-mode: screen;
        font-weight: 700;
        grid-row: 1/2;
        grid-column: 1/2;
    }

    #glitchbox h1:nth-child(1) {
        color: #f00;
        filter: blur(1.5px);
        mix-blend-mode: lighten;
    }

    #glitchbox p:nth-child(2) {
        color: #00fd00;
        mix-blend-mode: lighten;
        filter: blur(1.5px);
        padding-left: 3px;
    }

    #glitchbox p:nth-child(3) {
        color: #0000ff;
        filter: blur(1.5px);
        mix-blend-mode: lighten;
        padding-left: 6px;
    }

    #details {
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    #aboutlists {
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    #samegenre {
        display: flex;
        justify-content: end;
    }

    @media (min-width: 850px) {
    
        #outer {
            display: grid;
            grid-template-columns: 2fr 1fr;
        }

        #inner {
            order: -1;
        }

        #details {
            width: fit-content;
            place-self: end end;
        }
   }
</style>