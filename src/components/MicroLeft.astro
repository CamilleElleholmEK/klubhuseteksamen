---
const {title} = Astro.props
---
<div class="micro">
<img src="/imgs/sliceBtmLeft.svg" alt="Graphic element">
<p>{title}</p>
</div>

<style>
    .micro {
       display: none; 
    }

    @media (min-width: 850px) {
        .micro {
            display: flex;
            font-size: 11px;
            align-items: center;
        }

        .micro img {
            width: 12px;
            height: 12px;
            margin-right: 32px;
        }
    }
</style>