---
const {project} = Astro.props
---

<a href="/">
<article>
<img src={project.albumcover.replace(/^"|"$/g, '')} />
<div class="textbox">
    <div class="left">
        <p>{project.artist}</p>
        <p>{project.titel_album}</p>
    </div>
    <div class="right">
        <p>{project.producer}</p>
        <p>Placeholder text</p>
    </div>
</div>
</article>
</a>

<style>
    a {
        text-decoration: none;
        color: var(--secondary);
    }

    /* article {
        width: 90vw;
        height: auto;
    } */

    .textbox{
        display: flex;
        justify-content: space-between;
        text-decoration: none;
    }

    .right {
        text-align: right;
    }

    .left p:nth-child(1) {
        color: var(--contrast);
    }

    p {
        margin-top: 8px;
    }

</style>