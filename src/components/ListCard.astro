---
const {project} = Astro.props
---

<a href="/" class="listcard" data-producer={project.producer} data-genre={JSON.stringify(project.genre)} data-role={JSON.stringify(project.role)} data-year={project.year} data-artist={project.artist}>
<article>
<img src={project.albumcover.replace(/^"|"$/g, '')} />
<div class="textbox">
    <div class="top">
        <p>{project.artist}</p>
        <p>{project.producer}</p>
    </div>
    <div class="bottom">
        <p>{project.titel_album}</p>
    
    </div>
</div>
</article>
</a>

<style>
    .hide {
        display: none;
        border: none;
    }

    article {
        margin-bottom: 15px;
        border-bottom: solid 0.5px var(--secondary);
    }

    img {
        border-radius: 3px;
        aspect-ratio: 1/1;
    }
    
    a {
        text-decoration: none;
        color: var(--secondary);
        display: grid;
    }

    .top{
        display: flex;
        justify-content: space-between;
        text-decoration: none;
    }

    .top p:nth-child(1) {
        color: var(--contrast);
    }

    p {
        margin-top: 8px;
    }

    @media (min-width: 850px) {
        article {
            margin-bottom: 0;
        }
    }

</style>