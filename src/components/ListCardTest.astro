---
const {project} = Astro.props;
---

<a href=`/details/${project.titel_album}` class="listcard" data-producer={project.producer} data-genre={JSON.stringify(project.genre)} data-role={JSON.stringify(project.role)} data-year={project.year} data-artist={project.artist} data-titel_album={project.albumcover.replace(/^"|"$/g, '')} data-spotify={project.spotify.replace(/^"|"$/g, '')}>
<article>
  <div id="imgwrap">
   <img src={project.albumcover.replace(/^"|"$/g, '')} alt="Album cover"/>
 </div>
 <div id="tekst">
    <p>{project.year}</p>
    <p>{project.titel_album}</p>
    <p>{project.artist}</p>
    <p>{project.producer}</p>
 </div>
</article>
</a>

<style>
    .hide {
        display: none;
        border: none;
    }

    article {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: 1fr;
        overflow: hidden;
        margin-bottom: 32px;
    }
    
    #imgwrap, #tekst {
        grid-column: 1/2;
        grid-row: 1/2;
    }

    img {
        border-radius: 10px;
    }

    a {
        text-decoration: none;
    }

    #tekst {
        z-index: 20;
        background: linear-gradient(0deg, #000 25%, rgba(0, 0, 0, 0.00) 100%);
        height: 70%;
        align-self: end;
        display: flex;
        flex-direction: column;
        justify-content: end;
        color: var(--secondary);
        padding-left: 16px;
        padding-bottom: 16px;
        border-radius: 0px 0px 10px 10px;
    }

    #tekst p:nth-child(2) {
        font-family: var(--gopher);
        font-size: 22px;
        font-weight: var(--bold);
        text-transform: none;
        line-height: 25.75px;
        margin-bottom: 2px;
    }

    #tekst p:nth-child(3) {
        font-size: 16.5px;
        font-weight: var(--book);
        text-transform: none;
        line-height: 25.75px;
        margin-bottom: 2px;
    }

    #tekst p:nth-child(4) {
        font-size: 12px;
        font-weight: var(--regular);
        text-transform: none;
        line-height: 16px;
        color: var(--contrast);
    }
    #tekst p:nth-child(1) {
        font-size: 12px;
        font-weight: var(--regular);
        text-transform: none;
        line-height: 16px;
        color: var(--contrast);
    }

    @media (min-width: 850px) {
        #tekst {
        height: 44%;
        transition: height 0.5s;
    }

    #tekst p:nth-child(1) {
        font-size: 12px;
        line-height: 28px;
    }

    #tekst p:nth-child(2) {
        font-size: 24px;
        line-height: 28px;
    }

    #tekst p:nth-child(3) {
        font-size: 18px;
        line-height: 28px;
    }

    #tekst p:nth-child(4) {
        color: transparent;
        transition: color 0.5s, margin-top 0.5s;
        margin-top: -18px;
    }
    

    a:hover #tekst {
        height: 70%;
    }

    a:hover #tekst p:nth-child(4) {
        color: var(--contrast);
        margin-top: 0;
    }
    }

</style>